---
/**
 * ContactForm - Multilingual contact form with validation and Web3Forms support
 *
 * @example
 * ```astro
 * <ContactForm accessKey="YOUR_ACCESS_KEY" lang="fr" />
 * ```
 */

import type { Lang } from '@/config/navigation';

interface Props {
  /** Web3Forms access key — leave empty for demo mode */
  accessKey?: string;
  lang?: Lang;
}

const { accessKey = '', lang = 'en' } = Astro.props;

const t = {
  en: {
    firstName: 'First name',
    lastName: 'Last name',
    email: 'Email',
    subject: 'Subject',
    message: 'Message',
    placeholderFirstName: 'Jane',
    placeholderLastName: 'Doe',
    placeholderEmail: 'jane@example.com',
    placeholderSubject: "What's on your mind?",
    placeholderMessage: 'Tell us how we can help...',
    send: 'Send Message',
    sending: 'Sending...',
    required: 'Required fields',
    successTitle: 'Message sent successfully!',
    successText: "We'll get back to you within 24 hours.",
    errorTitle: 'Something went wrong',
    errorText: 'Please try again or contact us directly via email.',
    validationRequired: 'is required',
    validationMinChars: 'must be at least {n} characters',
    validationEmail: 'Please enter a valid email address',
    privacy: '🔒 Your data is never shared with third parties.',
  },
  fr: {
    firstName: 'Prénom',
    lastName: 'Nom',
    email: 'Email',
    subject: 'Objet',
    message: 'Message',
    placeholderFirstName: 'Marie',
    placeholderLastName: 'Dupont',
    placeholderEmail: 'marie@exemple.com',
    placeholderSubject: 'Quel est votre sujet ?',
    placeholderMessage: 'Dites-nous comment nous pouvons vous aider...',
    send: 'Envoyer',
    sending: 'Envoi en cours...',
    required: 'Champs obligatoires',
    successTitle: 'Message envoyé avec succès !',
    successText: 'Nous vous répondrons dans les 24 heures.',
    errorTitle: 'Une erreur est survenue',
    errorText: 'Veuillez réessayer ou nous contacter directement par email.',
    validationRequired: 'est requis',
    validationMinChars: 'doit contenir au moins {n} caractères',
    validationEmail: 'Veuillez entrer une adresse email valide',
    privacy: '🔒 Vos données ne sont jamais partagées avec des tiers.',
  },
  es: {
    firstName: 'Nombre',
    lastName: 'Apellido',
    email: 'Email',
    subject: 'Asunto',
    message: 'Mensaje',
    placeholderFirstName: 'María',
    placeholderLastName: 'García',
    placeholderEmail: 'maria@ejemplo.com',
    placeholderSubject: '¿Cuál es su consulta?',
    placeholderMessage: 'Díganos cómo podemos ayudarle...',
    send: 'Enviar',
    sending: 'Enviando...',
    required: 'Campos obligatorios',
    successTitle: '¡Mensaje enviado con éxito!',
    successText: 'Le responderemos en un plazo de 24 horas.',
    errorTitle: 'Algo salió mal',
    errorText: 'Por favor, inténtelo de nuevo o contáctenos directamente por email.',
    validationRequired: 'es obligatorio',
    validationMinChars: 'debe tener al menos {n} caracteres',
    validationEmail: 'Por favor, introduzca una dirección de email válida',
    privacy: '🔒 Sus datos nunca se comparten con terceros.',
  },
}[lang];
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-6"
  novalidate
  data-lang={lang}
  data-has-access-key={accessKey ? 'true' : 'false'}
  data-validation-required={t.validationRequired}
  data-validation-min-chars={t.validationMinChars}
  data-validation-email={t.validationEmail}
  data-label-first-name={t.firstName}
  data-label-last-name={t.lastName}
  data-label-email={t.email}
  data-label-subject={t.subject}
  data-label-message={t.message}
>
  <!-- Web3Forms access key -->
  <input type="hidden" name="access_key" value={accessKey} />
  <!-- Web3Forms: prefix subject in email -->
  <input type="hidden" name="from_name" value="MailLighter Contact Form" />
  <!-- Web3Forms: disable redirect after submission -->
  <input type="hidden" name="redirect" value="false" />

  <!-- Honeypot field for spam protection (Web3Forms) -->
  <div class="hidden" aria-hidden="true">
    <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="firstName" class="block text-sm font-medium text-text mb-2">
        {t.firstName} <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="firstName"
        name="firstName"
        required
        minlength="2"
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
        placeholder={t.placeholderFirstName}
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="firstName"></p>
    </div>
    <div>
      <label for="lastName" class="block text-sm font-medium text-text mb-2">
        {t.lastName} <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="lastName"
        name="lastName"
        required
        minlength="2"
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
        placeholder={t.placeholderLastName}
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="lastName"></p>
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-text mb-2">
      {t.email} <span class="text-red-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
      placeholder={t.placeholderEmail}
    />
    <p class="mt-1 text-sm text-red-500 hidden" data-error="email"></p>
  </div>

  <div>
    <label for="subject" class="block text-sm font-medium text-text mb-2">
      {t.subject} <span class="text-red-500">*</span>
    </label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      minlength="2"
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
      placeholder={t.placeholderSubject}
    />
    <p class="mt-1 text-sm text-red-500 hidden" data-error="subject"></p>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-text mb-2">
      {t.message} <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      minlength="10"
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none transition-colors"
      placeholder={t.placeholderMessage}></textarea>
    <p class="mt-1 text-sm text-red-500 hidden" data-error="message"></p>
  </div>

  <!-- Form status messages -->
  <div id="form-status" class="hidden">
    <div
      id="form-success"
      class="hidden p-4 rounded-md bg-green-100 dark:bg-green-950 border border-green-300 dark:border-green-800"
    >
      <p class="text-green-900 dark:text-green-100 font-medium">{t.successTitle}</p>
      <p class="text-green-800 dark:text-green-300 text-sm mt-1">
        {t.successText}
      </p>
    </div>
    <div
      id="form-error"
      class="hidden p-4 rounded-md bg-red-100 dark:bg-red-950 border border-red-300 dark:border-red-800"
    >
      <p class="text-red-900 dark:text-red-100 font-medium">{t.errorTitle}</p>
      <p class="text-red-800 dark:text-red-300 text-sm mt-1">
        {t.errorText}
      </p>
    </div>
  </div>

  <button
    type="submit"
    id="submit-button"
    class="w-full py-3.5 rounded-lg bg-[var(--ml-blue)] text-white font-bold text-[0.95rem] cursor-pointer flex items-center justify-center gap-2 shadow-[0_4px_16px_rgba(21,100,192,0.3)] transition-all duration-200 hover:bg-[var(--ml-blue-dark)] hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(21,100,192,0.35)] focus:outline-none focus:ring-2 focus:ring-[var(--ml-blue)] focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed mt-1"
  >
    <span id="button-text" class="inline-flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2L2 6l4 4 4 4 4-12zM6 10l2-2"/></svg>
      {t.send}
    </span>
    <span id="button-loading" class="inline-flex items-center gap-2" style="display: none;">
      <svg
        class="animate-spin w-5 h-5"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
      {t.sending}
    </span>
  </button>
  <p class="text-xs text-center mt-3" style="color: var(--ml-ink-mute);">{t.privacy}</p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const buttonLoading = document.getElementById('button-loading');
  const formStatus = document.getElementById('form-status');
  const formSuccess = document.getElementById('form-success');
  const formError = document.getElementById('form-error');

  // Read translated validation messages from data attributes
  const requiredMsg = form.dataset.validationRequired || 'is required';
  const minCharsMsg = form.dataset.validationMinChars || 'must be at least {n} characters';
  const emailMsg = form.dataset.validationEmail || 'Please enter a valid email address';

  // Field labels for validation messages
  const fieldLabels: Record<string, string> = {
    firstName: form.dataset.labelFirstName || 'First name',
    lastName: form.dataset.labelLastName || 'Last name',
    email: form.dataset.labelEmail || 'Email',
    subject: form.dataset.labelSubject || 'Subject',
    message: form.dataset.labelMessage || 'Message',
  };

  // Validation rules
  const validationRules: Record<string, (value: string) => string | null> = {
    firstName: (value) => {
      if (!value.trim()) return `${fieldLabels.firstName} ${requiredMsg}`;
      if (value.trim().length < 2) return `${fieldLabels.firstName} ${minCharsMsg.replace('{n}', '2')}`;
      return null;
    },
    lastName: (value) => {
      if (!value.trim()) return `${fieldLabels.lastName} ${requiredMsg}`;
      if (value.trim().length < 2) return `${fieldLabels.lastName} ${minCharsMsg.replace('{n}', '2')}`;
      return null;
    },
    email: (value) => {
      if (!value.trim()) return `${fieldLabels.email} ${requiredMsg}`;
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(value)) return emailMsg;
      return null;
    },
    subject: (value) => {
      if (!value.trim()) return `${fieldLabels.subject} ${requiredMsg}`;
      if (value.trim().length < 2) return `${fieldLabels.subject} ${minCharsMsg.replace('{n}', '2')}`;
      return null;
    },
    message: (value) => {
      if (!value.trim()) return `${fieldLabels.message} ${requiredMsg}`;
      if (value.trim().length < 10) return `${fieldLabels.message} ${minCharsMsg.replace('{n}', '10')}`;
      return null;
    },
  };

  // Show/hide error message
  function showError(fieldName: string, message: string | null) {
    const errorEl = document.querySelector(`[data-error="${fieldName}"]`);
    const inputEl = document.getElementById(fieldName);

    if (errorEl && inputEl) {
      if (message) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
        inputEl.classList.add('border-red-500');
        inputEl.classList.remove('border-border');
      } else {
        errorEl.classList.add('hidden');
        inputEl.classList.remove('border-red-500');
        inputEl.classList.add('border-border');
      }
    }
  }

  // Validate single field
  function validateField(fieldName: string): boolean {
    const input = form.elements.namedItem(fieldName) as
      | HTMLInputElement
      | HTMLSelectElement
      | HTMLTextAreaElement;
    if (!input || !validationRules[fieldName]) return true;

    const error = validationRules[fieldName](input.value);
    showError(fieldName, error);
    return !error;
  }

  // Validate all fields
  function validateForm(): boolean {
    let isValid = true;
    for (const fieldName of Object.keys(validationRules)) {
      if (!validateField(fieldName)) {
        isValid = false;
      }
    }
    return isValid;
  }

  // Real-time validation on blur
  for (const fieldName of Object.keys(validationRules)) {
    const input = form.elements.namedItem(fieldName) as
      | HTMLInputElement
      | HTMLSelectElement
      | HTMLTextAreaElement
      | null;
    if (input && 'addEventListener' in input) {
      input.addEventListener('blur', () => validateField(fieldName));
      input.addEventListener('input', () => {
        // Clear error on input if field was previously invalid
        const errorEl = document.querySelector(`[data-error="${fieldName}"]`);
        if (errorEl && !errorEl.classList.contains('hidden')) {
          validateField(fieldName);
        }
      });
    }
  }

  // Form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Hide previous status messages
    formStatus?.classList.add('hidden');
    formSuccess?.classList.add('hidden');
    formError?.classList.add('hidden');

    // Validate form
    if (!validateForm()) {
      // Focus first invalid field
      const firstError = form.querySelector('.border-red-500') as HTMLElement;
      firstError?.focus();
      return;
    }

    // Show loading state
    submitButton.disabled = true;
    if (buttonText) buttonText.style.display = 'none';
    if (buttonLoading) buttonLoading.style.display = 'inline-flex';

    const formData = new FormData(form);
    const hasAccessKey = form.dataset.hasAccessKey === 'true';

    try {
      // If no access key, simulate success (demo mode)
      if (!hasAccessKey) {
        await new Promise((resolve) => setTimeout(resolve, 1500));
        showSuccess();
        return;
      }

      // Submit to Web3Forms
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          Accept: 'application/json',
        },
      });

      if (response.ok) {
        showSuccess();
      } else {
        showErrorState();
      }
    } catch {
      showErrorState();
    }
  });

  function showSuccess() {
    formStatus?.classList.remove('hidden');
    formSuccess?.classList.remove('hidden');
    form.reset();
    resetButtonState();
  }

  function showErrorState() {
    formStatus?.classList.remove('hidden');
    formError?.classList.remove('hidden');
    resetButtonState();
  }

  function resetButtonState() {
    submitButton.disabled = false;
    if (buttonText) buttonText.style.display = 'inline-flex';
    if (buttonLoading) buttonLoading.style.display = 'none';
  }
</script>
