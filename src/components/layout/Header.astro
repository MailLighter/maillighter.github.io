---
/**
 * Header - Site header with responsive navigation
 *
 * @description
 * A sticky site header that includes logo, navigation links, theme toggle,
 * and a mobile-friendly hamburger menu. Navigation items are automatically
 * filtered based on feature flags from site config.
 *
 * @example
 * ```astro
 * <Header />
 * ```
 */
import { siteConfig } from '@/config';
import { navigationByLang, type Lang } from '@/config/navigation';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import type { FeatureFlags } from '@/lib/types';

const { features } = siteConfig;

// Detect language from URL path
const pathname = Astro.url.pathname;
const lang: Lang = pathname.startsWith('/fr') ? 'fr' : pathname.startsWith('/es') ? 'es' : 'en';
const { header: headerNav } = navigationByLang[lang];

// Filter navigation items based on feature flags
const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

// Separate CTA buttons by variant
const ghostCTAs = headerNav.cta.filter((cta) => cta.variant === 'ghost');
const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');

const langLabels: Record<Lang, string> = { en: 'English', fr: 'Français', es: 'Español' };
---

<header
  id="site-header"
  class="sticky top-0 z-50 p-1.5 bg-background/80 backdrop-blur-md border-b border-surface"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Site Name -->
      <a href="/" class="flex items-center gap-2 font-semibold text-lg text-text">
        {
          siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto" />
          ) : (
            siteConfig.name
          )
        }
      </a>

      <!-- Desktop Navigation - Left -->
      <div class="hidden md:flex items-center gap-6 ml-8">
        {
          mainNavItems.map((item) => (
            <a
              href={item.href}
              class="text-text-muted hover:text-primary transition-colors text-sm font-medium rounded-md px-2 py-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background focus:outline-none"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- Desktop Actions - Right -->
      <div class="hidden md:flex items-center gap-4 ml-auto">
        <ThemeToggle />
        <!-- Language Switcher -->
        <div class="relative flex items-center">
          <Icon name="lucide:languages" class="absolute left-2 w-4 h-4 text-text-muted pointer-events-none" aria-hidden="true" />
          <label class="sr-only" for="lang-select-desktop">Select language</label>
          <select
            id="lang-select-desktop"
            class="lang-select appearance-none pl-7 pr-6 py-1.5 text-sm bg-background border border-border rounded-md text-text hover:border-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary cursor-pointer dark:[color-scheme:dark]"
          >
            {(['en', 'fr', 'es'] as Lang[]).map((l) => (
              <option value={l} data-lang={l} selected={lang === l}>{langLabels[l]}</option>
            ))}
          </select>
          <Icon name="lucide:chevron-down" class="absolute right-1.5 w-3 h-3 text-text-muted pointer-events-none" aria-hidden="true" />
        </div>
        {
          primaryCTA && (
            <a
              href={primaryCTA.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md bg-green-600 text-white text-sm font-medium hover:bg-green-700 transition-colors shadow-sm hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {primaryCTA.label}
            </a>
          )
        }
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          type="button"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="p-2 rounded-md hover:bg-surface transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        >
          <Icon
            name="lucide:menu"
            id="menu-icon-open"
            class="w-6 h-6 text-text"
            aria-hidden="true"
          />
          <Icon
            name="lucide:x"
            id="menu-icon-close"
            class="hidden w-6 h-6 text-text"
            aria-hidden="true"
          />
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile Navigation Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation menu"
>
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-background/80 backdrop-blur-sm"></div>
  <!-- Menu Panel -->
  <nav
    id="mobile-menu-panel"
    class="absolute left-0 right-0 bg-surface border-b border-background shadow-lg"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-4 space-y-1">
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class="block px-3 py-3 rounded-md text-primary hover:text-primary-dark hover:bg-background transition-colors text-base font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
          >
            {item.label}
          </a>
        ))
      }
      <!-- Divider -->
      <div class="border-t border-border my-2"></div>
      <!-- Language Switcher (mobile) -->
      <div class="px-3 py-3">
        <div class="relative flex items-center">
          <Icon name="lucide:languages" class="absolute left-2 w-4 h-4 text-text-muted pointer-events-none" aria-hidden="true" />
          <label class="sr-only" for="lang-select-mobile">Select language</label>
          <select
            id="lang-select-mobile"
            class="lang-select w-full appearance-none pl-7 pr-6 py-2 text-sm bg-background border border-border rounded-md text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-primary cursor-pointer dark:[color-scheme:dark]"
          >
            {(['en', 'fr', 'es'] as Lang[]).map((l) => (
              <option value={l} data-lang={l} selected={lang === l}>{langLabels[l]}</option>
            ))}
          </select>
          <Icon name="lucide:chevron-down" class="absolute right-2 w-3 h-3 text-text-muted pointer-events-none" aria-hidden="true" />
        </div>
      </div>
      {
        primaryCTA && (
          <a
            href={primaryCTA.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 px-3 py-3 rounded-md bg-green-600 text-white hover:bg-green-700 transition-colors text-base font-medium text-center shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-inset"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {primaryCTA.label}
          </a>
        )
      }
    </div>
  </nav>
</div>

<script>
  const header = document.getElementById('site-header');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function updateMenuPosition() {
    if (header && mobileMenuPanel) {
      const headerRect = header.getBoundingClientRect();
      mobileMenuPanel.style.top = `${headerRect.bottom}px`;
    }
  }

  function openMobileMenu() {
    updateMenuPosition();
    mobileMenu?.classList.remove('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'true');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'false');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function toggleMobileMenu() {
    const isExpanded = mobileMenuButton?.getAttribute('aria-expanded') === 'true';
    if (isExpanded) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  }

  mobileMenuButton?.addEventListener('click', toggleMobileMenu);
  mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenuButton?.getAttribute('aria-expanded') === 'true') {
      closeMobileMenu();
      mobileMenuButton?.focus();
    }
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Language select dropdowns
  function syncLangSelects() {
    const path = window.location.pathname;
    const currentLang = path.startsWith('/fr') ? 'fr' : path.startsWith('/es') ? 'es' : 'en';
    document.querySelectorAll<HTMLSelectElement>('.lang-select').forEach((select) => {
      select.value = currentLang;
    });
  }

  function getLocalizedPath(targetLang: 'en' | 'fr' | 'es'): string {
    const url = new URL(window.location.href);
    const currentPath = url.pathname;
    const pathWithoutLang = currentPath.replace(/^\/(fr|es)(?=\/|$)/, '') || '/';
    const normalizedPath =
      pathWithoutLang.length > 1 && pathWithoutLang.endsWith('/')
        ? pathWithoutLang.slice(0, -1)
        : pathWithoutLang;

    // Only these routes (or prefixes) are localized today.
    const localizedRoutes = new Set(['/','/faq','/contact','/privacy']);
    const isLocalized = localizedRoutes.has(normalizedPath) || normalizedPath.startsWith('/docs');
    if (!isLocalized) {
      return `${url.pathname}${url.search}${url.hash}`;
    }

    const nextPath =
      targetLang === 'en'
        ? normalizedPath
        : `/${targetLang}${normalizedPath === '/' ? '/' : normalizedPath}`;

    return `${nextPath}${url.search}${url.hash}`;
  }

  document.querySelectorAll<HTMLSelectElement>('.lang-select').forEach((select) => {
    select.addEventListener('change', () => {
      const selected = select.options[select.selectedIndex];
      const selectedLang = selected.dataset.lang as 'en' | 'fr' | 'es' | undefined;
      if (!selectedLang) return;

      localStorage.setItem('preferred-lang', selectedLang);
      window.location.assign(getLocalizedPath(selectedLang));
    });
  });

  // Always sync on page show (covers bfcache back/forward navigation)
  window.addEventListener('pageshow', syncLangSelects);
</script>
