---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`${siteConfig.name} — Allégez vos emails, allégez votre impact`}
  description="Le plugin Outlook qui nettoie vos emails en un clic. Pour des échanges plus clairs, des serveurs moins chargés et une sobriété numérique concrète."
>
  <!-- HERO -->
  <Hero
    title="MailLighter pour Outlook"
    subtitle="Allégez vos emails. Allégez votre impact."
    backgroundType="gradient"
    gradient="from-primary/10 via-background to-background"
  >
    <Fragment slot="title">
      <img src="/images/logo-full.png" alt="MailLighter" width="1016" height="207" fetchpriority="high" class="h-16 sm:h-20 w-auto mx-auto mb-2" />
      <span class="block text-2xl sm:text-3xl font-semibold">pour Outlook</span>
    </Fragment>
  </Hero>

  <!-- HERO CONTENT + AVANT / APRÈS -->
  <section class="pt-4 pb-16 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Colonne gauche : accroche + CTA -->
      <div>
        <div class="inline-flex items-center gap-1.5 bg-success-bg border border-success/30 text-success px-4 py-1.5 rounded-full text-xs font-semibold mb-6">🌿 Pour des emails plus légers, pour une planète plus légère</div>
        <h2 class="text-3xl sm:text-4xl font-black text-text tracking-tight leading-tight mb-5">Chaque email que vous envoyez a un <span class="bg-gradient-to-r from-green-700 to-green-500 bg-clip-text text-transparent">poids sur la planète.</span></h2>
        <p class="text-base sm:text-lg text-text-muted leading-relaxed mb-8">
          Images inutiles, pièces jointes oubliées, histoires de réponses empilés sur des semaines —
          vos emails transportent des mégaoctets que personne ne relira jamais.
          <strong class="text-text">MailLighter</strong> nettoie tout ça en un clic, sans quitter Outlook.
        </p>
        <div class="flex gap-3 flex-wrap mb-3">
          <a href="https://appsource.microsoft.com/" class="inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-green-600/30 transition hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-600/40">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Installer gratuitement
          </a>
        </div>
        <p class="text-xs text-text-muted">Add-in gratuit · Outlook Desktop · Windows &amp; macOS</p>
      </div>

      <!-- Colonne droite : Avant / Après -->
      <div class="flex items-center justify-center gap-4 sm:gap-6">
        <div class="bg-gradient-to-br from-error-bg to-background border-[1.5px] border-error/30 rounded-2xl p-5 sm:p-6 text-center w-40 sm:w-44 shadow-lg">
          <div class="text-[0.65rem] font-bold uppercase tracking-widest text-error mb-2">Avant</div>
          <div class="text-3xl mb-1">📧</div>
          <div class="text-3xl sm:text-4xl font-extrabold text-text leading-none">4.2 <small class="text-base font-semibold text-text-muted">MB</small></div>
          <div class="flex flex-col gap-0.5 text-[0.72rem] text-text-muted my-2">
            <span>12 images intégrées</span>
            <span>3 pièces jointes</span>
            <span>8 réponses citées</span>
          </div>
          <div class="text-sm font-bold text-error pt-2 border-t border-border">≈ 12 g CO₂</div>
        </div>

        <svg class="arrow-anim shrink-0" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" class="text-success"/><polyline points="12 5 19 12 12 19" class="text-success"/>
        </svg>

        <div class="bg-gradient-to-br from-success-bg to-background border-[1.5px] border-success/30 rounded-2xl p-5 sm:p-6 text-center w-40 sm:w-44 shadow-lg scale-105">
          <div class="text-[0.65rem] font-bold uppercase tracking-widest text-success mb-2">Après</div>
          <div class="text-3xl mb-1">✉️</div>
          <div class="text-3xl sm:text-4xl font-extrabold text-text leading-none">18 <small class="text-base font-semibold text-text-muted">KB</small></div>
          <div class="flex flex-col gap-0.5 text-[0.72rem] text-text-muted my-2">
            <span>Texte uniquement</span>
            <span>2 réponses récentes</span>
          </div>
          <div class="text-sm font-bold text-success pt-2 border-t border-border">≈ 0.05 g CO₂</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="bg-gray-900 text-white py-12 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">300 Mds</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">d'emails envoyés chaque jour dans le monde</div>
      </div>
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">3 à 4 %</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">des émissions de GES mondiales sont attribuées au numérique</div>
      </div>
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">~200×</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">moins de données en transit avec un email allégé par MailLighter</div>
      </div>
    </div>
  </div>

  <!-- ECO SECTION -->
  <section class="py-24 px-6 bg-gradient-to-br from-success-bg to-background" id="eco">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-4">🌍 Impact environnemental</div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight leading-tight mb-5">Vos emails ont une empreinte carbone. Réduisons-la ensemble.</h2>
        <div class="text-base text-text-muted leading-relaxed space-y-4">
          <p>Chaque mégaoctet envoyé transite par des datacenters, est répliqué dans des systèmes de sauvegarde, et reste stocké pendant des années. Un seul email volumineux transféré à 10 personnes peut générer <strong class="text-text">plusieurs grammes de CO₂</strong> — invisibles, mais réels.</p>
          <p>MailLighter agit <strong class="text-text">à la source</strong>, avant l'envoi. Moins de données = moins de stockage = moins d'énergie. <strong class="text-text">Un petit réflexe, un vrai impact cumulé.</strong></p>
        </div>
      </div>
      <div class="bg-background rounded-2xl p-8 shadow-lg border border-border">
        <h3 class="text-base font-bold text-text mb-5">Ce que MailLighter évite, email par email</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🖥️</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Moins de stockage serveur</strong> — chaque email allégé occupe moins de place dans les datacenters de votre messagerie.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">📡</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Moins de bande passante</strong> — transférer un email de 18 Ko au lieu de 4 Mo, c'est ~200× moins de données en transit.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🔋</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Moins d'énergie</strong> — les serveurs de mail maintiennent vos données en vie en permanence. Moins de données = moins de watts.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🌱</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Effet de levier collectif</strong> — si 1 000 utilisateurs allègent 10 emails par jour, ce sont des téraoctets économisés chaque mois.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24 px-6" id="features">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-3">⚡ Fonctionnalités</div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight">Cinq actions, un seul clic.</h2>
        <p class="text-base text-text-muted mt-3">Disponibles directement dans le ruban Outlook, sans jamais quitter votre email.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">🖼️</div>
          <div class="text-base font-bold text-text mb-2">Supprimer les images</div>
          <div class="text-sm text-text-muted leading-relaxed">Retire toutes les images intégrées du corps du message. MailLighter vous indique le nombre et la taille économisée.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Espace libéré affiché</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">📎</div>
          <div class="text-base font-bold text-text mb-2">Supprimer les pièces jointes</div>
          <div class="text-sm text-text-muted leading-relaxed">Supprime les fichiers joints. Les images inline des signatures ne sont pas touchées.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Intelligent</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">↩️</div>
          <div class="text-base font-bold text-text mb-2">Garder 2 réponses</div>
          <div class="text-sm text-text-muted leading-relaxed">Réduit les longs fils aux 2 messages les plus récents. Détecte les blocs cités dans tous les formats Outlook et en plusieurs langues.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Multi-langues</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">✂️</div>
          <div class="text-base font-bold text-text mb-2">Garder la sélection</div>
          <div class="text-sm text-text-muted leading-relaxed">Remplacez l'intégralité du fil cité par le seul passage que vous avez sélectionné. Précision chirurgicale.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Sélection HTML</span>
        </div>
        <div class="bg-gradient-to-br from-success-bg to-background border border-success/30 rounded-2xl p-7 transition hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">✅</div>
          <div class="text-base font-bold text-text mb-2">Nettoyage complet</div>
          <div class="text-sm text-text-muted leading-relaxed">Lance toutes les actions en une seule fois. Un résumé détaillé s'affiche : images, pièces jointes, réponses — tout en un coup.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Tout-en-un</span>
        </div>
        <div class="bg-gray-900 border border-transparent rounded-2xl p-7 transition hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">🔒</div>
          <div class="text-base font-bold text-white mb-2">100 % local</div>
          <div class="text-sm text-gray-400 leading-relaxed">Tout le traitement s'effectue dans Outlook via l'API Office.js. Aucune donnée n'est envoyée à un serveur externe.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-green-400/15 text-green-400 px-2.5 py-0.5 rounded-full">Respect de la vie privée</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 px-6 bg-surface" id="how">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-3">🚀 Comment ça marche</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight mb-2">En trois étapes, c'est réglé.</h2>
      <p class="text-base text-text-muted mb-12">Pas de configuration complexe. Pas de compte à créer.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-6">
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">1</div>
          <div class="font-bold text-text mb-1">Installez l'add-in</div>
          <div class="text-sm text-text-muted leading-relaxed">Téléchargez MailLighter depuis le Microsoft AppSource et ajoutez-le à Outlook en quelques secondes.</div>
        </div>
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">2</div>
          <div class="font-bold text-text mb-1">Composez votre email</div>
          <div class="text-sm text-text-muted leading-relaxed">Rédigez ou répondez à un email comme d'habitude. Le menu MailLighter est disponible dans le ruban.</div>
        </div>
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">3</div>
          <div class="font-bold text-text mb-1">Allégez avant d'envoyer</div>
          <div class="text-sm text-text-muted leading-relaxed">Choisissez l'action souhaitée. MailLighter s'exécute en un instant et vous indique ce qui a été supprimé.</div>
        </div>
      </div>

      <div class="mt-10 bg-gray-900 rounded-xl px-6 py-5 flex items-center gap-3 text-left max-w-xl mx-auto">
        <span class="text-2xl shrink-0">✅</span>
        <span class="text-sm text-green-200 font-mono">Nettoyage complet — Images : 8 (1.2 MB) | Pièces jointes : 2 (3.4 MB) | Réponses : 6 → 2</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 text-center" id="download">
    <div class="max-w-2xl mx-auto">
      <div class="inline-flex items-center gap-1.5 bg-success-bg border border-success/30 text-success px-4 py-1.5 rounded-full text-xs font-semibold mb-5">🌿 Adoptez le réflexe email responsable</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight mb-4">Prêt à alléger vos emails <span class="bg-gradient-to-r from-green-700 to-green-500 bg-clip-text text-transparent">et votre impact ?</span></h2>
      <p class="text-base text-text-muted mb-8 leading-relaxed">Gratuit, sans compte, sans collecte de données. Installez MailLighter en quelques secondes et commencez à envoyer des emails plus propres dès aujourd'hui.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="https://appsource.microsoft.com/" class="inline-flex items-center gap-2 bg-green-600 text-white px-7 py-3.5 rounded-xl font-bold shadow-lg shadow-green-600/30 transition hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-600/40">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Installer gratuitement
        </a>
      </div>
      <p class="text-xs text-text-muted mt-4">Outlook Desktop · Windows &amp; macOS · Microsoft 365 ou Exchange</p>
    </div>
  </section>
</MarketingLayout>

<style>
  @keyframes slide {
    0%, 100% { transform: translateX(0); opacity: 0.6; }
    50% { transform: translateX(7px); opacity: 1; }
  }
  .arrow-anim { animation: slide 2s ease-in-out infinite; }
</style>
