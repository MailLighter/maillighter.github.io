---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { siteConfig } from '@/config';

const { legal } = siteConfig;
---

<MarketingLayout
  title={`Privacy Policy - ${siteConfig.name}`}
  description={`Privacy Policy for ${siteConfig.name}. Learn how we handle your data with transparency and respect.`}
>
  <!-- HERO -->
  <section class="privacy-hero">
    <div class="privacy-hero-inner">
      <span class="privacy-eyebrow">Privacy</span>
      <h1 class="privacy-title">Privacy Policy</h1>
      <p class="privacy-sub">How MailLighter handles your data — with transparency and respect. Last updated: {legal.lastUpdated}</p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="privacy-body">

    <div class="privacy-section">
      <h2>Overview</h2>
      <p>
        MailLighter is a free Outlook add-in that optimizes email attachments to reduce their environmental footprint.
        We are committed to keeping your data private and secure. This policy explains what limited information we collect
        and how we use it.
      </p>
    </div>

    <div class="privacy-section">
      <h2>What We Collect</h2>
      <p>MailLighter collects <strong>very little data</strong>. Here is what may be collected:</p>
      <div class="privacy-card">
        <h3>Contact form</h3>
        <p>If you contact us through our website, we collect your first name, last name, email address, and message. This data is processed by <a href="https://web3forms.com/privacy" target="_blank" rel="noopener noreferrer">Web3Forms</a> and sent to us by email.</p>
      </div>
      <div class="privacy-card">
        <h3>Outlook add-in</h3>
        <p>MailLighter processes your email attachments <strong>locally within Outlook</strong>. No email content, attachment, or personal data is sent to external servers. The add-in does not require an account and does not track your usage.</p>
      </div>
    </div>

    <div class="privacy-section">
      <h2>What We Do NOT Collect</h2>
      <ul class="privacy-list">
        <li>We do <strong>not</strong> use cookies or tracking technologies on this website</li>
        <li>We do <strong>not</strong> use analytics services (no Google Analytics, no tracking pixels)</li>
        <li>We do <strong>not</strong> collect payment information — MailLighter is free</li>
        <li>We do <strong>not</strong> require account creation</li>
        <li>We do <strong>not</strong> sell or share personal data with third parties</li>
        <li>We do <strong>not</strong> store email content or attachments</li>
      </ul>
    </div>

    <div class="privacy-section">
      <h2>How We Use Your Information</h2>
      <p>The only personal data we may receive — from the contact form — is used solely to respond to your inquiry. We do not use it for marketing, profiling, or any other purpose.</p>
    </div>

    <div class="privacy-section">
      <h2>Data Security</h2>
      <p>
        Our website is served over HTTPS. Contact form submissions are encrypted in transit via Web3Forms' secure API.
        We do not store form data on our own servers — messages are delivered directly to our email inbox.
      </p>
    </div>

    <div class="privacy-section">
      <h2>Your Rights</h2>
      <p>Under the GDPR and other applicable data protection laws, you have the right to:</p>
      <ul class="privacy-list">
        <li><strong>Access</strong> — Request a copy of any personal data we may hold</li>
        <li><strong>Correction</strong> — Ask us to correct inaccurate information</li>
        <li><strong>Deletion</strong> — Ask us to delete your personal data</li>
      </ul>
      <p>Since we collect minimal data, exercising these rights is straightforward. Simply contact us at the address below.</p>
    </div>

    <div class="privacy-section">
      <h2>Third-Party Links</h2>
      <p>
        Our website may contain links to external sites (GitHub, Microsoft AppSource). We are not responsible for the privacy practices of these external services. We encourage you to review their privacy policies.
      </p>
    </div>

    <div class="privacy-section">
      <h2>Children's Privacy</h2>
      <p>
        Our services are not directed at children under 16. We do not knowingly collect personal information from children.
      </p>
    </div>

    <div class="privacy-section">
      <h2>Changes to This Policy</h2>
      <p>
        We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated date. Since we do not collect email addresses for notifications, we encourage you to review this page periodically.
      </p>
    </div>

    <div class="privacy-section">
      <h2>Contact Us</h2>
      <p>If you have any questions about this Privacy Policy, you can reach us at:</p>
      <div class="privacy-contact">
        <a href={`mailto:${legal.privacyEmail}`}>{legal.privacyEmail}</a>
        <span class="privacy-sep">or</span>
        <a href="/contact">Contact form</a>
      </div>
    </div>

  </section>
</MarketingLayout>

<style>
  .privacy-hero {
    padding: 100px 52px 56px;
    text-align: center;
  }
  .privacy-hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .privacy-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--ml-blue-pale);
    color: var(--ml-blue);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 6px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .privacy-title {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .privacy-sub {
    font-size: 1rem;
    color: var(--ml-ink-soft);
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto;
  }

  .privacy-body {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 52px 100px;
  }

  .privacy-section {
    margin-bottom: 48px;
  }
  .privacy-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--ml-border);
  }
  .privacy-section h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .privacy-section p {
    font-size: 0.92rem;
    color: var(--ml-ink-soft);
    line-height: 1.75;
    margin-bottom: 12px;
  }
  .privacy-section a {
    color: var(--ml-blue);
    text-decoration: none;
    font-weight: 500;
  }
  .privacy-section a:hover {
    text-decoration: underline;
  }

  .privacy-card {
    background: var(--ml-surface);
    border: 1px solid var(--ml-border);
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 12px;
  }

  .privacy-list {
    list-style: none;
    padding: 0;
    margin: 0 0 12px;
  }
  .privacy-list li {
    position: relative;
    padding-left: 24px;
    font-size: 0.92rem;
    color: var(--ml-ink-soft);
    line-height: 1.75;
    margin-bottom: 6px;
  }
  .privacy-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ml-blue);
    opacity: 0.4;
  }

  .privacy-contact {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .privacy-contact a {
    color: var(--ml-blue);
    font-weight: 600;
    text-decoration: none;
  }
  .privacy-contact a:hover {
    text-decoration: underline;
  }
  .privacy-sep {
    color: var(--ml-ink-mute);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .privacy-hero { padding: 80px 24px 40px; }
    .privacy-body { padding: 0 24px 60px; }
  }
</style>
