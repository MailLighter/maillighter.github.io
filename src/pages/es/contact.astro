---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ContactForm from '@forms/ContactForm.astro';
import { siteConfig } from '@/config';

const contactFAQs = [
  {
    question: '¿Cómo instalo MailLighter?',
    answer:
      'MailLighter está disponible en Microsoft Marketplace. Instálelo directamente desde allí en su entorno de Outlook.',
  },
  {
    question: '¿Es MailLighter compatible con mi versión de Outlook?',
    answer:
      'MailLighter funciona con entornos Microsoft 365 (Outlook de escritorio y Outlook en la web).',
  },
  {
    question: '¿Están seguros mis datos con MailLighter?',
    answer:
      'Sí. MailLighter procesa los correos localmente y cumple plenamente con el RGPD. Ningún dato abandona su entorno.',
  },
];
---

<MarketingLayout
  title={`Contacto - ${siteConfig.name}`}
  description="Póngase en contacto con el equipo de MailLighter. Estamos aquí para responder sus preguntas sobre nuestro plugin."
>
  <div class="contact-wrap">
    <!-- LEFT -->
    <div class="contact-left">
      <span class="page-eyebrow">Contacto</span>
      <h1 class="contact-title">Nos encantaría saber de usted.</h1>
      <p class="contact-sub">¿Una pregunta, un bug, una idea de funcionalidad? Envíenos un mensaje — leemos cada correo y normalmente respondemos en menos de 24 horas.</p>

      <!-- Preguntas frecuentes -->
      <div class="contact-faq">
        <h2 class="contact-faq-title">Preguntas frecuentes</h2>
        <div class="contact-faq-list">
          {contactFAQs.map((faq) => (
            <div class="contact-faq-item">
              <h3 class="contact-faq-q">{faq.question}</h3>
              <p class="contact-faq-a">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Redes sociales (solo GitHub) -->
      <div class="social-links">
        {siteConfig.social.github && (
          <a href={siteConfig.social.github} class="social-link" title="GitHub" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.167 6.839 9.49.5.09.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.03-2.682-.103-.253-.447-1.27.098-2.646 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.376.202 2.393.1 2.646.64.698 1.026 1.591 1.026 2.682 0 3.841-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          </a>
        )}
        <a href="https://www.linkedin.com/company/maillighter" class="social-link" title="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>

    <!-- FORM -->
    <div class="contact-form-wrap">
      <div class="form-title">Envíenos un mensaje</div>
      <div class="form-sub">Rellene el formulario y le responderemos lo antes posible.</div>
      <ContactForm accessKey="490a3f5f-4387-4922-bba3-147f540ce414" lang="es" />
    </div>
  </div>
</MarketingLayout>

<style>
  .contact-wrap {
    max-width: 1100px; margin: 0 auto; padding: 120px 52px 100px;
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start;
  }
  .page-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--ml-blue-pale); color: var(--ml-blue);
    font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-radius: 6px;
    letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 16px;
  }
  .contact-title {
    font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 800;
    color: var(--ml-ink); line-height: 1.1; margin-bottom: 16px;
  }
  .contact-sub {
    font-size: 1rem; color: var(--ml-ink-soft); line-height: 1.75; margin-bottom: 40px;
  }

  .contact-faq { margin-bottom: 32px; }
  .contact-faq-title {
    font-size: 1.15rem; font-weight: 700; color: var(--ml-ink); margin-bottom: 18px;
  }
  .contact-faq-list { display: flex; flex-direction: column; gap: 16px; }
  .contact-faq-item {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 18px 20px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .contact-faq-item:hover { border-color: var(--ml-blue-light); transform: translateX(4px); }
  .contact-faq-q { font-size: 0.9rem; font-weight: 600; color: var(--ml-ink); margin-bottom: 4px; }
  .contact-faq-a { font-size: 0.82rem; color: var(--ml-ink-soft); line-height: 1.6; }

  .social-links { display: flex; gap: 10px; margin-top: 8px; }
  .social-link {
    width: 38px; height: 38px; border-radius: 9px;
    border: 1.5px solid var(--color-border); background: var(--color-surface);
    display: flex; align-items: center; justify-content: center;
    color: var(--ml-ink-soft); text-decoration: none; transition: all 0.2s;
  }
  .social-link:hover { border-color: var(--ml-blue); color: var(--ml-blue); transform: translateY(-2px); }
  .social-link svg { width: 17px; height: 17px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

  .contact-form-wrap {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 20px; padding: 40px;
    box-shadow: 0 8px 40px var(--ml-shadow);
  }
  .form-title { font-size: 1.5rem; font-weight: 800; color: var(--ml-ink); margin-bottom: 6px; }
  .form-sub { font-size: 0.87rem; color: var(--ml-ink-soft); margin-bottom: 28px; }

  @media (max-width: 768px) {
    .contact-wrap { grid-template-columns: 1fr; gap: 40px; padding: 100px 20px 60px; }
  }
</style>
