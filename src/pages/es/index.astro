---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`${siteConfig.name} — Aligere sus correos, aligere su impacto`}
  description="El plugin de Outlook que limpia sus correos en un clic. Para intercambios más claros, servidores menos cargados y una sobriedad digital concreta."
>
  <!-- ════ HERO ════ -->
  <section class="landing-hero">
    <div class="hero-grid">
      <div class="hero-left">
        <span class="hero-badge">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="var(--ml-blue)" stroke-width="1.8"><path d="M6 1v10M3 8l3 3 3-3" stroke-linecap="round"/></svg>
          Add-in Outlook gratuito&nbsp;<span class="badge-accent">Sin cuenta</span>
        </span>
        <h1 class="hero-title">
          <span class="accent-blue">Aligere</span> sus correos.<br>
          <span class="accent-green">Aligere su impacto.</span>
        </h1>
        <p class="hero-sub">MailLighter elimina imágenes inútiles, archivos adjuntos olvidados y cadenas de respuestas interminables — en un clic, directamente desde la cinta de Outlook.</p>
        <div class="hero-ctas">
          <a href="https://marketplace.microsoft.com/" class="btn-primary" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7.5 2v8M5 7l2.5 3 2.5-3M2 12h11"/></svg>
            Instalar gratis
          </a>
          <a href="#features" class="btn-ghost">Ver cómo funciona →</a>
        </div>
        <div class="hero-trust">
          <a href="https://marketplace.microsoft.com/" class="appsource-badge" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 16 16"><rect width="7" height="7" rx="1" fill="#f25022"/><rect x="9" width="7" height="7" rx="1" fill="#7fba00"/><rect y="9" width="7" height="7" rx="1" fill="#00a4ef"/><rect x="9" y="9" width="7" height="7" rx="1" fill="#ffb900"/></svg>
            Microsoft Marketplace
          </a>
          <span class="trust-sep">·</span>
          <span class="trust-text">Outlook Desktop & Web · Windows & macOS · Microsoft 365</span>
        </div>
      </div>
      <div class="hero-right">
        <div class="outlook-mockup">
          <div class="mock-titlebar">
            <div class="tbar-dot"></div><div class="tbar-dot"></div><div class="tbar-dot"></div>
            <span class="tbar-title">Nuevo correo — Microsoft Outlook</span>
          </div>
          <div class="mock-ribbon">
            <div class="rbtn">Enviar</div>
            <div class="rbtn">Adjuntar</div>
            <div class="rsep"></div>
            <div class="rbtn blue">⚡ MailLighter</div>
            <div class="rbtn green-outline">Limpieza completa</div>
            <div class="rbtn">Imágenes</div>
            <div class="rbtn">2 respuestas</div>
          </div>
          <div class="mock-body">
            <div class="mock-header">
              <div class="mock-row"><span class="mock-lbl">Para:</span><span class="mock-val">equipo@empresa.es (12 destinatarios)</span></div>
              <div class="mock-row"><span class="mock-lbl">Asunto:</span><span class="mock-val">Re: Informe T4 — Revisión final</span></div>
            </div>
            <div class="mock-text">
              <p style="margin-bottom:8px">Hola a todos, a continuación encontrarán la versión actualizada.</p>
              <div class="mock-asset"><span class="mock-asset-icon">🖼️</span> banner_empresa.png — <strong>820 KB</strong></div>
              <div class="mock-asset"><span class="mock-asset-icon">📎</span> informe_T4_final_v3.xlsx — <strong>3.4 MB</strong></div>
              <div class="mock-quoted">— Mensaje original (8 respuestas, 3 semanas de historial) —<br>De: Marc · 14 nov · Enviado: Re: Re: Re: Re: Informe T4…</div>
            </div>
            <div class="mock-result">
              <span class="mock-result-icon">✅</span>
              <div><strong>Limpieza completa terminada</strong><br>Imágenes: 1 eliminada (820 KB) · Adjuntos: 1 eliminado (3.4 MB)<br>Respuestas: 8 → 2 conservadas · <strong>Total ahorrado: 4.2 MB</strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ STATS ════ -->
  <section class="stats-band">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-num">300<span class="stat-unit"> Mds</span></div>
        <div class="stat-label">de correos enviados cada día en el mundo</div>
        <span class="stat-badge">volumen diario</span>
      </div>
      <div class="stat-item">
        <div class="stat-num">3–<span class="stat-unit">4 %</span></div>
        <div class="stat-label">de las emisiones mundiales de GEI atribuidas al sector digital</div>
        <span class="stat-badge">impacto GEI</span>
      </div>
      <div class="stat-item">
        <div class="stat-num">~<span class="stat-unit">200×</span></div>
        <div class="stat-label">menos datos en tránsito tras una limpieza de MailLighter</div>
        <span class="stat-badge">ahorro</span>
      </div>
    </div>
  </section>

  <!-- ════ BEFORE / AFTER ════ -->
  <section class="ba-section">
    <div class="ba-header">
      <span class="section-eyebrow green">Impacto real</span>
      <h2 class="section-title">Un clic. Una diferencia medible.</h2>
      <p class="section-sub">La transformación concreta en un correo real.</p>
    </div>
    <div class="ba-cards">
      <div class="ba-card">
        <div class="ba-label">📧 Antes</div>
        <div class="ba-size red">2.8 MB</div>
        <div class="ba-details">8 imágenes incrustadas<br>2 adjuntos olvidados<br>4 semanas de historial</div>
        <span class="ba-chip bad">🌡️ ≈ 8 g CO₂</span>
      </div>
      <div class="ba-divider">
        <div class="ba-arrow-circle">→</div>
        <div class="ba-ratio">150×<br>más ligero</div>
      </div>
      <div class="ba-card after">
        <div class="ba-label green">✉️ Después de MailLighter</div>
        <div class="ba-size green">18 KB</div>
        <div class="ba-details">Solo texto<br>2 respuestas recientes conservadas<br>Nada superfluo</div>
        <span class="ba-chip good">🌿 ≈ 0.05 g CO₂</span>
      </div>
    </div>
  </section>

  <!-- ════ FEATURES ════ -->
  <section class="features-section" id="features">
    <div class="features-inner">
      <span class="section-eyebrow">Características</span>
      <h2 class="section-title">Cinco acciones. Un solo clic.</h2>
      <p class="section-sub">Todo accesible directamente desde la cinta de Outlook. Sin configuración.</p>
      <div class="features-grid">
        <div class="fcard featured">
          <div class="fcard-icon green"><svg viewBox="0 0 20 20"><circle cx="10" cy="10" r="8"/><polyline points="7,10 9,12 13,8"/></svg></div>
          <span class="fcard-tag green">⭐ Más usado</span>
          <div class="fcard-name">Limpieza completa</div>
          <div class="fcard-desc">Ejecuta todas las acciones a la vez. Imágenes, adjuntos, hilos de respuestas — limpiados de un golpe. Un resumen detallado muestra exactamente lo que se eliminó.</div>
        </div>
        <div class="fcard">
          <div class="fcard-icon"><svg viewBox="0 0 20 20"><rect x="2" y="2" width="16" height="12" rx="2"/><line x1="7" y1="18" x2="13" y2="18"/><line x1="10" y1="14" x2="10" y2="18"/></svg></div>
          <span class="fcard-tag">Inteligente</span>
          <div class="fcard-name">Eliminar imágenes</div>
          <div class="fcard-desc">Elimina todas las imágenes incrustadas del cuerpo del mensaje. Las imágenes de firma se preservan.</div>
        </div>
        <div class="fcard">
          <div class="fcard-icon"><svg viewBox="0 0 20 20"><path d="M13 2H6a2 2 0 00-2 2v14l6-3 6 3V4a2 2 0 00-2-2z"/></svg></div>
          <span class="fcard-tag">Seguro</span>
          <div class="fcard-name">Eliminar adjuntos</div>
          <div class="fcard-desc">Elimina los archivos adjuntos del hilo. Las imágenes inline de las firmas se preservan.</div>
        </div>
        <div class="fcard">
          <div class="fcard-icon"><svg viewBox="0 0 20 20"><polyline points="15,10 10,15 5,10"/><line x1="10" y1="4" x2="10" y2="15"/></svg></div>
          <span class="fcard-tag">Multi-idioma</span>
          <div class="fcard-name">Conservar 2 respuestas</div>
          <div class="fcard-desc">Reduce los hilos largos a los 2 mensajes más recientes. Detecta bloques citados en todos los idiomas.</div>
        </div>
        <div class="fcard">
          <div class="fcard-icon"><svg viewBox="0 0 20 20"><path d="M17 3a2.828 2.828 0 11-4 4L6 14H3v-3L10 4a2.828 2.828 0 014-1z"/></svg></div>
          <span class="fcard-tag">Quirúrgico</span>
          <div class="fcard-name">Conservar la selección</div>
          <div class="fcard-desc">Reemplace todo el hilo por únicamente el texto que seleccionó. Precisión total.</div>
        </div>
        <div class="fcard">
          <div class="fcard-icon"><svg viewBox="0 0 20 20"><rect x="3" y="11" width="14" height="8" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/><circle cx="10" cy="15" r="1" fill="#93c5fd"/></svg></div>
          <span class="fcard-tag">Privacidad</span>
          <div class="fcard-name">100 % local</div>
          <div class="fcard-desc">Funciona completamente dentro de Outlook vía Office.js. Ningún dato sale de su dispositivo.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ SOCIAL PROOF ════ -->
  <section class="social-section">
    <span class="section-eyebrow">Opiniones</span>
    <h2 class="section-title">Adoptado por equipos comprometidos.</h2>
    <p class="section-sub">Utilizado por miles de profesionales que han adoptado el hábito del correo responsable. Sus opiniones llegan pronto :)</p>
    <!-- Testimonios a reactivar más tarde con opiniones reales
    <div class="testimonials">
      <div class="tcard">
        <div class="stars">★★★★★</div>
        <p class="tcard-text">"Por fin una herramienta que hace algo <strong>concreto e inmediato</strong> por la huella de carbono digital. Toma 2 segundos, y el resultado es visible."</p>
        <div class="tcard-author"><div class="avatar">SL</div><div><div class="author-name">Sophie L.</div><div class="author-role">Responsable de sostenibilidad</div></div></div>
      </div>
      <div class="tcard">
        <div class="stars">★★★★★</div>
        <p class="tcard-text">"Uso la Limpieza completa en cada correo antes de enviarlo. <strong>Ahorro varios MB al día</strong> sin siquiera pensarlo."</p>
        <div class="tcard-author"><div class="avatar">TM</div><div><div class="author-name">Thomas M.</div><div class="author-role">Jefe de proyecto</div></div></div>
      </div>
      <div class="tcard">
        <div class="stars">★★★★☆</div>
        <p class="tcard-text">"Simple, efectivo, cero curva de aprendizaje. Desearía que todos los plugins de Outlook estuvieran tan <strong>bien diseñados</strong>."</p>
        <div class="tcard-author"><div class="avatar">AM</div><div><div class="author-name">Alice M.</div><div class="author-role">Directora IT</div></div></div>
      </div>
    </div>
    -->
  </section>

  <!-- ════ HOW IT WORKS ════ -->
  <section class="hiw-section">
    <div class="hiw-inner">
      <span class="section-eyebrow">Primeros pasos</span>
      <h2 class="section-title">Operativo en 60 segundos.</h2>
      <p class="section-sub">Sin cuenta que crear, sin configuración compleja.</p>
      <div class="hiw-steps">
        <div class="hiw-step">
          <div class="step-circle">1</div>
          <div class="step-title">Instale el add-in</div>
          <div class="step-desc">Descargue MailLighter desde Microsoft Marketplace y añádalo a Outlook en segundos.</div>
        </div>
        <div class="hiw-connector">→</div>
        <div class="hiw-step">
          <div class="step-circle">2</div>
          <div class="step-title">Redacte su correo</div>
          <div class="step-desc">Escriba o responda como de costumbre. El menú MailLighter aparece en la cinta.</div>
        </div>
        <div class="hiw-connector">→</div>
        <div class="hiw-step">
          <div class="step-circle">3</div>
          <div class="step-title">Aligere antes de enviar</div>
          <div class="step-desc">Elija su acción. MailLighter se ejecuta al instante y le muestra lo que fue limpiado.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ FINAL CTA ════ -->
  <section class="final-cta-wrap">
    <div class="final-cta-box">
      <span class="section-eyebrow">¿Listo?</span>
      <h2 class="section-title">Empiece a aligerar sus correos hoy mismo.</h2>
      <p class="section-sub">Gratuito, sin cuenta, sin recopilación de datos. Instale MailLighter en segundos.</p>
      <a href="https://marketplace.microsoft.com/" class="btn-cta" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M8 2v9M5 8l3 3 3-3M2 13h12"/></svg>
        Instalar gratis en Marketplace
      </a>
      <div class="cta-pills">
        <span class="cpill"><span class="cpill-dot"></span> Outlook Desktop & Web</span>
        <span class="cpill"><span class="cpill-dot"></span> Windows & macOS</span>
        <span class="cpill"><span class="cpill-dot"></span> Microsoft 365 & Exchange</span>
        <span class="cpill"><span class="cpill-dot"></span> 100 % gratuito</span>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ══════════════════════════════
     LANDING PAGE — scoped styles
     ══════════════════════════════ */

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── HERO ── */
  .landing-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 52px 80px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 56px;
  }
  .hero-left { display: flex; flex-direction: column; gap: 24px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--ml-blue-pale); border: 1px solid var(--ml-blue-light); color: var(--ml-blue);
    font-size: 0.75rem; font-weight: 700; padding: 5px 12px; border-radius: 6px;
    width: fit-content; letter-spacing: 0.05em; text-transform: uppercase;
    animation: fadeUp 0.5s ease both;
  }
  .badge-accent { background: var(--ml-green); color: white; padding: 1px 7px; border-radius: 4px; font-size: 0.7rem; }
  .hero-title {
    font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 800;
    line-height: 1.1; color: var(--ml-ink); animation: fadeUp 0.5s 0.1s ease both;
  }
  .accent-blue { color: var(--ml-blue); }
  .accent-green { color: var(--ml-green); font-style: italic; }
  .hero-sub {
    font-size: 1.05rem; line-height: 1.75; color: var(--ml-ink-soft);
    max-width: 460px; animation: fadeUp 0.5s 0.2s ease both;
  }
  .hero-ctas { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; animation: fadeUp 0.5s 0.3s ease both; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--ml-blue); color: white;
    padding: 13px 26px; border-radius: 8px; font-weight: 600; font-size: 0.95rem;
    text-decoration: none; box-shadow: 0 4px 16px rgba(21,100,192,0.3);
    transition: background 0.22s, transform 0.22s, box-shadow 0.22s;
  }
  .btn-primary:hover { background: var(--ml-blue-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(21,100,192,0.35); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--ml-ink-soft); font-weight: 500; font-size: 0.9rem;
    text-decoration: none; border: 1px solid var(--color-border);
    padding: 12px 22px; border-radius: 8px;
    background: var(--color-surface); transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--ml-blue); color: var(--ml-blue); }

  .hero-trust { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; animation: fadeUp 0.5s 0.4s ease both; }
  .appsource-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 7px; padding: 7px 14px;
    font-size: 0.78rem; font-weight: 600; color: var(--ml-ink); text-decoration: none;
    transition: border-color 0.2s;
  }
  .appsource-badge:hover { border-color: var(--ml-blue); }
  .trust-sep { color: var(--color-border); }
  .trust-text { font-size: 0.78rem; color: var(--ml-ink-mute); }

  /* ── OUTLOOK MOCKUP ── */
  .hero-right { animation: fadeUp 0.5s 0.15s ease both; }
  .outlook-mockup {
    background: var(--ml-mock-bg); border-radius: 14px; overflow: hidden;
    box-shadow: 0 20px 70px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.08);
    border: 1px solid var(--ml-mock-border);
  }
  .mock-titlebar { background: #1e3a5f; padding: 9px 14px; display: flex; align-items: center; gap: 6px; }
  .tbar-dot { width: 9px; height: 9px; border-radius: 50%; background: rgba(255,255,255,0.25); }
  .tbar-title { color: rgba(255,255,255,0.85); font-size: 0.75rem; font-weight: 500; margin-left: 8px; }
  .mock-ribbon {
    background: var(--ml-mock-ribbon); padding: 6px 10px;
    display: flex; align-items: center; gap: 5px;
    border-bottom: 1px solid var(--ml-mock-ribbon-border); flex-wrap: wrap;
  }
  .rbtn {
    background: var(--ml-mock-rbtn); border: 1px solid var(--ml-mock-border);
    border-radius: 4px; padding: 4px 9px; font-size: 0.7rem;
    color: var(--ml-mock-rbtn-c); white-space: nowrap;
  }
  .rbtn.blue { background: var(--ml-blue); border-color: var(--ml-blue); color: white; font-weight: 700; }
  .rbtn.green-outline { border-color: var(--ml-green); color: var(--ml-green); font-weight: 600; }
  .rsep { width: 1px; height: 18px; background: var(--ml-mock-border); margin: 0 3px; }
  .mock-body { background: var(--ml-mock-body); padding: 18px 20px; }
  .mock-header { padding-bottom: 12px; margin-bottom: 12px; border-bottom: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 5px; }
  .mock-row { display: flex; gap: 8px; font-size: 0.76rem; }
  .mock-lbl { color: var(--ml-ink-mute); min-width: 36px; }
  .mock-val { color: var(--ml-ink); font-weight: 500; }
  .mock-text { font-size: 0.8rem; color: var(--ml-ink-soft); line-height: 1.6; }
  .mock-asset {
    background: var(--ml-mock-asset-bg); border: 1px dashed var(--ml-mock-asset-border);
    border-radius: 6px; padding: 8px 12px;
    display: flex; align-items: center; gap: 8px;
    font-size: 0.72rem; color: var(--ml-ink-mute); margin: 8px 0;
  }
  .mock-asset-icon { font-size: 1rem; }
  .mock-quoted { font-size: 0.72rem; color: var(--ml-ink-mute); border-left: 2px solid var(--color-border); padding-left: 8px; margin-top: 8px; line-height: 1.6; }
  .mock-result {
    margin-top: 12px; background: var(--ml-green-pale); border: 1px solid var(--ml-green-light);
    border-radius: 8px; padding: 10px 14px;
    display: flex; align-items: flex-start; gap: 8px;
    font-size: 0.73rem; line-height: 1.6; color: var(--ml-ink-soft);
  }
  .mock-result strong { color: var(--ml-green-dark); }
  :global(.dark) .mock-result strong { color: var(--ml-green); }
  .mock-result-icon { font-size: 1rem; flex-shrink: 0; }

  /* ── STATS BAND ── */
  .stats-band {
    background: linear-gradient(135deg, var(--ml-blue-deeper) 0%, var(--ml-blue-dark) 50%, #1a5c8a 100%);
    padding: 60px 52px;
  }
  .stats-inner { display: flex; max-width: 960px; margin: 0 auto; }
  .stat-item {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 0 36px; text-align: center; position: relative;
  }
  .stat-item:not(:last-child)::after {
    content: ''; position: absolute; right: 0; top: 10%; height: 80%;
    width: 1px; background: rgba(255,255,255,0.15);
  }
  .stat-num { font-size: clamp(2.2rem, 3vw, 3rem); color: white; line-height: 1; font-weight: 800; }
  .stat-unit { color: var(--ml-green); }
  .stat-label { font-size: 0.83rem; color: rgba(255,255,255,0.65); line-height: 1.5; max-width: 150px; }
  .stat-badge {
    display: inline-block; background: rgba(74,162,81,0.25); color: #86efac;
    font-size: 0.68rem; font-weight: 700; padding: 2px 9px; border-radius: 4px;
    letter-spacing: 0.06em; text-transform: uppercase;
  }

  /* ── SECTION COMMONS ── */
  .section-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--ml-blue-pale); color: var(--ml-blue);
    font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-radius: 6px;
    letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 14px;
  }
  .section-eyebrow.green { background: var(--ml-green-pale); color: var(--ml-green-dark); }
  :global(.dark) .section-eyebrow.green { color: var(--ml-green); }
  .section-title {
    font-size: clamp(1.9rem, 3vw, 2.8rem); font-weight: 800;
    color: var(--ml-ink); line-height: 1.15; margin-bottom: 14px;
  }
  .section-sub { font-size: 1rem; color: var(--ml-ink-soft); line-height: 1.7; max-width: 520px; margin-bottom: 48px; }

  /* ── BEFORE / AFTER ── */
  .ba-section { padding: 100px 52px; max-width: 1100px; margin: 0 auto; }
  .ba-header { text-align: center; }
  .ba-header .section-sub { margin: 0 auto 48px; }
  .ba-cards { display: grid; grid-template-columns: 1fr 56px 1fr; align-items: center; }
