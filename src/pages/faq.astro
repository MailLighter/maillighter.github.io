---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import { siteConfig } from '@/config';

const categories = [
  {
    name: 'General',
    faqs: [
      {
        question: 'What is MailLighter?',
        answer:
          'MailLighter is an Outlook plugin that cleans your emails in one click. It removes unnecessary attachments, embedded images, and old reply chains to make your emails lighter and reduce your digital footprint.',
      },
      {
        question: 'Is MailLighter free?',
        answer:
          'Please visit the Microsoft Marketplace marketplace for the latest pricing information and available plans.',
      },
      {
        question: 'Who is MailLighter for?',
        answer:
          'MailLighter is designed for any organization that wants to reduce the environmental impact of its emails: private companies, public organizations, IT departments, CSR teams, and anyone committed to responsible digital practices.',
      },
    ],
  },
  {
    name: 'Installation & Compatibility',
    faqs: [
      {
        question: 'How do I install MailLighter?',
        answer:
          'MailLighter is available on the Microsoft Marketplace marketplace. Simply search for "MailLighter" and install it directly into your Outlook environment.',
      },
      {
        question: 'Which versions of Outlook are supported?',
        answer:
          'MailLighter is compatible with Microsoft 365 environments, including Outlook desktop and Outlook on the web.',
      },
      {
        question: 'Can I deploy MailLighter across my entire organization?',
        answer:
          'Yes. MailLighter can be deployed at scale through your Microsoft 365 admin center, making it easy to roll out to all users in your organization.',
      },
      {
        question: 'Does MailLighter require any special configuration?',
        answer:
          'No. MailLighter works out of the box with no configuration needed. Users simply click the MailLighter button in Outlook to clean their emails.',
      },
    ],
  },
  {
    name: 'Features',
    faqs: [
      {
        question: 'What does MailLighter remove from emails?',
        answer:
          'MailLighter can remove unnecessary attachments, embedded images (logos, banners, signature images), and old reply chains, keeping only the most recent messages in a thread.',
      },
      {
        question: 'Can I choose what to remove?',
        answer:
          'MailLighter provides smart defaults that work for most users. More details about customization options will be available soon.',
      },
      {
        question: 'Does MailLighter modify the original email?',
        answer:
          'MailLighter cleans the email content before sending or replying. The original received email remains unchanged in your mailbox.',
      },
    ],
  },
  {
    name: 'Security & Privacy',
    faqs: [
      {
        question: 'Is my data safe with MailLighter?',
        answer:
          'Yes. MailLighter processes emails locally within your environment. No email content is sent to external servers.',
      },
      {
        question: 'Is MailLighter GDPR compliant?',
        answer:
          'Yes. MailLighter is fully GDPR compliant. It does not collect, store, or transmit any personal data or email content.',
      },
      {
        question: 'Does MailLighter impact my organization\'s security?',
        answer:
          'No. MailLighter operates within the standard Microsoft 365 security framework and does not require any additional permissions beyond what is needed to process email content.',
      },
    ],
  },
  {
    name: 'Impact & CSR',
    faqs: [
      {
        question: 'How does MailLighter help with CSR reporting?',
        answer:
          'MailLighter provides a concrete, measurable action for your CSR/ESG reporting. By reducing email weight across your organization, you demonstrate operational commitment to digital sobriety.',
      },
      {
        question: 'What is the environmental impact of lighter emails?',
        answer:
          'Every lighter email means less data stored and replicated on servers, less bandwidth consumed, and less energy used. While the individual impact is modest, it becomes significant at organizational scale.',
      },
    ],
  },
];
---

<MarketingLayout
  title={`FAQ - ${siteConfig.name}`}
  description="Frequently asked questions about MailLighter, the Outlook plugin for lighter, more responsible emails."
>
  <!-- HERO -->
  <section class="faq-hero">
    <div class="faq-hero-inner">
      <span class="faq-eyebrow">FAQ</span>
      <h1 class="faq-title">Frequently Asked Questions</h1>
      <p class="faq-sub">Everything you need to know about MailLighter. Can't find the answer? <a href="/contact" class="faq-link">Contact us.</a></p>
    </div>
  </section>

  <FAQSection categories={categories} background="default" />

  <!-- CTA -->
  <section class="py-16 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-text tracking-tight mb-4">Didn’t find your answer?</h2>
      <p class="text-base text-text-muted mb-6">Contact us directly or install MailLighter to try it yourself.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-border font-semibold text-text hover:bg-surface transition">
          Contact us
        </a>
        <a href="https://marketplace.microsoft.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-green-600/30 transition hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-600/40">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Install for free
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .faq-hero {
    padding: 100px 52px 56px;
    text-align: center;
  }
  .faq-hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .faq-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--ml-blue-pale);
    color: var(--ml-blue);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 6px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .faq-title {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .faq-sub {
    font-size: 1rem;
    color: var(--ml-ink-soft);
    line-height: 1.75;
    max-width: 560px;
    margin: 0 auto;
  }
  .faq-link {
    color: var(--ml-blue);
    text-decoration: none;
    font-weight: 500;
  }
  .faq-link:hover {
    text-decoration: underline;
  }
</style>
