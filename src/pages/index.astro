---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const features = [
  {
    icon: 'lucide:scissors',
    title: 'Remove attachments',
    description:
      'Strip unnecessary attachments from emails before sending or replying. Keep your mailbox lean.',
  },
  {
    icon: 'lucide:image-off',
    title: 'Remove embedded images',
    description:
      'Clean up logos, banners, and inline images that bloat every email in the chain.',
  },
  {
    icon: 'lucide:list-collapse',
    title: 'Trim reply chains',
    description:
      'Keep only the most recent messages in a thread. Remove the endless trail of quoted replies.',
  },
  {
    icon: 'lucide:mouse-pointer-click',
    title: 'One-click action',
    description:
      'A single button in Outlook does it all. No settings to configure, no workflow to learn.',
  },
  {
    icon: 'lucide:shield-check',
    title: 'GDPR compliant',
    description:
      'All processing happens locally. No data leaves your environment. Fully respectful of your privacy.',
  },
  {
    icon: 'lucide:cloud-cog',
    title: 'Microsoft 365 compatible',
    description:
      'Works seamlessly with Microsoft 365 environments — Outlook desktop and Outlook on the web.',
  },
];

const bentoItems = [
  {
    title: 'Productivity & readability',
    description:
      'Shorter emails, clearer information, less noise, less scrolling. Faster decisions for everyone.',
    icon: 'lucide:trending-up',
    size: 'large' as const,
    accent: 'blue' as const,
  },
  {
    title: 'IT cost reduction',
    description: 'Less server storage, smaller backups, less bandwidth consumed. A more performant mailbox.',
    icon: 'lucide:server',
    accent: 'green' as const,
  },
  {
    title: 'Immediate CSR impact',
    description:
      'Every lighter email means less data stored and replicated, less energy consumed, a smaller digital footprint.',
    icon: 'lucide:leaf',
    accent: 'green' as const,
  },
  {
    title: 'Digital sobriety',
    description:
      'MailLighter turns every send into an act of digital sobriety. Small individual impact, massive at scale.',
    icon: 'lucide:globe',
    size: 'medium' as const,
    accent: 'primary' as const,
  },
];
---

<MarketingLayout
  title={`${siteConfig.name} — Lighter emails, lighter impact`}
  description={siteConfig.description}
>
  <!-- HERO -->
  <Hero
    title="MailLighter for Outlook"
    subtitle="Lighten your emails. Lighten your impact. The Outlook plugin that cleans your emails in one click. For clearer exchanges, lighter servers, and concrete digital sobriety."
    primaryCTA={{ label: 'Try it now', href: 'https://appsource.microsoft.com/' }}
    secondaryCTA={{ label: 'Learn more', href: '#problem' }}
    backgroundType="gradient"
    gradient="from-primary/10 via-background to-background"
  />

  <!-- PROBLEM SECTION -->
  <section id="problem" class="py-section bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">The problem today</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-text mb-6">
        Your emails are heavier than you think
      </h2>
      <p class="text-lg text-text-muted mb-10 max-w-2xl mx-auto">
        Every day, your colleagues send and receive duplicated attachments, useless embedded images, and endless email chains. This unnecessarily overloads mailboxes, servers, and teams — and increases your organization's digital carbon footprint.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-background rounded-lg p-6 border border-border">
          <div class="text-3xl mb-3">📎</div>
          <h3 class="font-semibold text-text mb-2">Duplicated attachments</h3>
          <p class="text-sm text-text-muted">The same files forwarded again and again in every reply.</p>
        </div>
        <div class="bg-background rounded-lg p-6 border border-border">
          <div class="text-3xl mb-3">🖼️</div>
          <h3 class="font-semibold text-text mb-2">Useless images</h3>
          <p class="text-sm text-text-muted">Logos, banners, signatures — embedded in every message of the chain.</p>
        </div>
        <div class="bg-background rounded-lg p-6 border border-border">
          <div class="text-3xl mb-3">🔁</div>
          <h3 class="font-semibold text-text mb-2">Endless chains</h3>
          <p class="text-sm text-text-muted">Threads with dozens of quoted replies that no one reads.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION SECTION -->
  <section id="solution" class="py-section bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-secondary uppercase tracking-wide mb-3">The solution</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-text mb-4">
        The Outlook button that keeps the essential — and removes the rest
      </h2>
      <p class="text-lg text-text-muted mb-10">
        In one click, directly in Outlook, without changing your habits.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="text-center">
          <div class="w-16 h-16 ml-gradient-bg rounded-xl flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-2xl">✂️</span>
          </div>
          <h3 class="font-semibold text-text mb-2">Remove attachments</h3>
          <p class="text-sm text-text-muted">Strip unnecessary files from the conversation.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 ml-gradient-bg rounded-xl flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-2xl">🖼️</span>
          </div>
          <h3 class="font-semibold text-text mb-2">Remove images</h3>
          <p class="text-sm text-text-muted">Clean up embedded images from signatures and chains.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 ml-gradient-bg rounded-xl flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-2xl">🧹</span>
          </div>
          <h3 class="font-semibold text-text mb-2">Clean replies</h3>
          <p class="text-sm text-text-muted">Keep only the latest messages in the thread.</p>
        </div>
      </div>

      <!-- Screenshot placeholder -->
      <div class="bg-surface border-2 border-dashed border-border rounded-xl p-12 max-w-2xl mx-auto">
        <div class="text-text-muted text-center">
          <div class="text-4xl mb-3">📸</div>
          <p class="font-medium">Screenshot coming soon</p>
          <p class="text-sm mt-1">MailLighter in action inside Outlook</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <FeaturesSection
    title="Everything you need, nothing more"
    subtitle="Simple, effective, and respectful. MailLighter integrates seamlessly into your daily workflow."
    features={features}
    background="muted"
    id="features"
  />

  <!-- BENEFITS (Bento Grid) -->
  <BentoGrid
    title="Measurable benefits"
    subtitle="For your teams, your IT, and the planet."
    items={bentoItems}
    background="default"
    id="benefits"
  />

  <!-- CSR SECTION -->
  <section class="py-section bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">A digital sobriety tool</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-text mb-4">
          Strengthen your CSR policy
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          MailLighter directly addresses everyday practices, reducing the volume and environmental impact of emails at the source.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
        {[
          { icon: '✅', text: 'Simple' },
          { icon: '✅', text: 'Low cost' },
          { icon: '✅', text: 'Easy to deploy' },
          { icon: '✅', text: 'No habit change' },
          { icon: '✅', text: 'Scalable' },
          { icon: '✅', text: 'Real impact' },
        ].map((item) => (
          <div class="flex items-center gap-2 bg-background rounded-lg p-4 border border-border">
            <span class="text-lg">{item.icon}</span>
            <span class="text-sm font-medium text-text">{item.text}</span>
          </div>
        ))}
      </div>

      <div class="bg-background rounded-xl p-8 border border-border">
        <h3 class="font-semibold text-text text-lg mb-4">MailLighter helps organizations:</h3>
        <ul class="space-y-3 text-text-muted">
          <li class="flex items-start gap-3">
            <span class="text-primary mt-0.5">→</span>
            <span>Meet expectations for <strong class="text-text">CSR / ESG reporting</strong>, internal audits, and Green IT initiatives</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-0.5">→</span>
            <span>Demonstrate <strong class="text-text">operational actions</strong>, not just declarations</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- AUDIENCE SECTION -->
  <section id="audience" class="py-section bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">Who is it for?</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-text mb-10">
        Built for organizations committed to responsible digital
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {[
          { icon: '🏢', title: 'Private companies' },
          { icon: '🏛️', title: 'Public organizations' },
          { icon: '💻', title: 'IT / CIO teams' },
          { icon: '🌱', title: 'CSR departments' },
          { icon: '🔧', title: 'IT departments' },
          { icon: '🌍', title: 'Responsible digital orgs' },
        ].map((item) => (
          <div class="bg-surface rounded-lg p-6 border border-border text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-medium text-text text-sm">{item.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DEPLOYMENT -->
  <HowItWorks
    title="Simple deployment"
    subtitle="Up and running in minutes."
    steps={[
      {
        title: 'Quick installation',
        description: 'Install from the Microsoft AppSource marketplace in a few clicks.',
        icon: 'lucide:download',
      },
      {
        title: 'Microsoft 365 compatible',
        description: 'Works with your existing Microsoft 365 environment. No migration needed.',
        icon: 'lucide:check-circle',
      },
      {
        title: 'Immediate adoption',
        description: 'No training needed. No security impact. GDPR compliant.',
        icon: 'lucide:rocket',
      },
    ]}
    variant="horizontal"
    background="muted"
  />

  <!-- CTA -->
  <CTA
    title="Lighter emails. More responsible digital."
    description="Try MailLighter today and make every email an act of digital sobriety."
    action={{ label: 'Try it now', href: 'https://appsource.microsoft.com/' }}
  />
</MarketingLayout>
