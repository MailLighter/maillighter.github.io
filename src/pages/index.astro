---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`${siteConfig.name} — Lighter emails, lighter impact`}
  description="The Outlook plugin that cleans your emails in one click. For clearer exchanges, lighter servers, and concrete digital sobriety."
>
  <!-- HERO -->
  <Hero
    title="MailLighter for Outlook"
    subtitle="Lighten your emails. Lighten your impact."
    backgroundType="gradient"
    gradient="from-primary/10 via-background to-background"
  >
    <Fragment slot="title">
      <img src="/images/logo-full.png" alt="MailLighter" width="1016" height="207" fetchpriority="high" class="h-16 sm:h-20 w-auto mx-auto mb-2" />
      <span class="block text-2xl sm:text-3xl font-semibold">for Outlook</span>
    </Fragment>
  </Hero>

  <!-- HERO CONTENT + BEFORE / AFTER -->
  <section class="pt-4 pb-16 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left column -->
      <div>
        <div class="inline-flex items-center gap-1.5 bg-success-bg border border-success/30 text-success px-4 py-1.5 rounded-full text-xs font-semibold mb-6">🌿 For lighter emails, for a lighter planet</div>
        <h2 class="text-3xl sm:text-4xl font-black text-text tracking-tight leading-tight mb-5">Every email you send has a <span class="bg-gradient-to-r from-green-700 to-green-500 bg-clip-text text-transparent">weight on the planet.</span></h2>
        <p class="text-base sm:text-lg text-text-muted leading-relaxed mb-8">
          Useless images, forgotten attachments, reply histories stacking up for weeks —
          your emails carry megabytes that no one will ever read again.
          <strong class="text-text">MailLighter</strong> cleans it all in one click, without leaving Outlook.
        </p>
        <div class="flex gap-3 flex-wrap mb-3">
          <a href="https://appsource.microsoft.com/" class="inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-green-600/30 transition hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-600/40">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Install for free
          </a>
        </div>
        <p class="text-xs text-text-muted">Free add-in · Outlook Desktop · Windows &amp; macOS</p>
      </div>

      <!-- Right column: Before / After -->
      <div class="flex items-center justify-center gap-4 sm:gap-6">
        <div class="bg-gradient-to-br from-error-bg to-background border-[1.5px] border-error/30 rounded-2xl p-5 sm:p-6 text-center w-40 sm:w-44 shadow-lg">
          <div class="text-[0.65rem] font-bold uppercase tracking-widest text-error mb-2">Before</div>
          <div class="text-3xl mb-1">📧</div>
          <div class="text-3xl sm:text-4xl font-extrabold text-text leading-none">4.2 <small class="text-base font-semibold text-text-muted">MB</small></div>
          <div class="flex flex-col gap-0.5 text-[0.72rem] text-text-muted my-2">
            <span>12 embedded images</span>
            <span>3 attachments</span>
            <span>8 quoted replies</span>
          </div>
          <div class="text-sm font-bold text-error pt-2 border-t border-border">≈ 12 g CO₂</div>
        </div>

        <svg class="arrow-anim shrink-0" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" class="text-success"/><polyline points="12 5 19 12 12 19" class="text-success"/>
        </svg>

        <div class="bg-gradient-to-br from-success-bg to-background border-[1.5px] border-success/30 rounded-2xl p-5 sm:p-6 text-center w-40 sm:w-44 shadow-lg scale-105">
          <div class="text-[0.65rem] font-bold uppercase tracking-widest text-success mb-2">After</div>
          <div class="text-3xl mb-1">✉️</div>
          <div class="text-3xl sm:text-4xl font-extrabold text-text leading-none">18 <small class="text-base font-semibold text-text-muted">KB</small></div>
          <div class="flex flex-col gap-0.5 text-[0.72rem] text-text-muted my-2">
            <span>Text only</span>
            <span>2 recent replies</span>
          </div>
          <div class="text-sm font-bold text-success pt-2 border-t border-border">≈ 0.05 g CO₂</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="bg-gray-900 text-white py-12 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">300 Bn</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">emails sent every day worldwide</div>
      </div>
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">3 to 4%</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">of global GHG emissions are attributed to the digital sector</div>
      </div>
      <div>
        <div class="text-4xl font-black text-green-400 tracking-tight">~200×</div>
        <div class="text-sm text-gray-400 mt-1 leading-snug">less data in transit with an email lightened by MailLighter</div>
      </div>
    </div>
  </div>

  <!-- ECO SECTION -->
  <section class="py-24 px-6 bg-gradient-to-br from-success-bg to-background" id="eco">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-4">🌍 Environmental impact</div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight leading-tight mb-5">Your emails have a carbon footprint. Let's reduce it together.</h2>
        <div class="text-base text-text-muted leading-relaxed space-y-4">
          <p>Every megabyte sent travels through data centres, is replicated in backup systems, and remains stored for years. A single large email forwarded to 10 people can generate <strong class="text-text">several grams of CO₂</strong> — invisible, but real.</p>
          <p>MailLighter acts <strong class="text-text">at the source</strong>, before sending. Less data = less storage = less energy. <strong class="text-text">A small habit, a real cumulative impact.</strong></p>
        </div>
      </div>
      <div class="bg-background rounded-2xl p-8 shadow-lg border border-border">
        <h3 class="text-base font-bold text-text mb-5">What MailLighter prevents, email by email</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🖥️</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Less server storage</strong> — every lighter email takes up less space in your messaging data centres.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">📡</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Less bandwidth</strong> — transferring an 18 KB email instead of 4 MB means ~200× less data in transit.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🔋</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Less energy</strong> — mail servers keep your data alive permanently. Less data = fewer watts.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl shrink-0">🌱</span>
            <p class="text-sm text-text-muted leading-snug"><strong class="text-text">Collective leverage</strong> — if 1,000 users lighten 10 emails a day, that's terabytes saved every month.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24 px-6" id="features">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-3">⚡ Features</div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight">Five actions, one single click.</h2>
        <p class="text-base text-text-muted mt-3">Available directly in the Outlook ribbon, without ever leaving your email.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">🖼️</div>
          <div class="text-base font-bold text-text mb-2">Remove images</div>
          <div class="text-sm text-text-muted leading-relaxed">Strips all embedded images from the message body. MailLighter shows you the count and space saved.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Space saved shown</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">📎</div>
          <div class="text-base font-bold text-text mb-2">Remove attachments</div>
          <div class="text-sm text-text-muted leading-relaxed">Removes attached files. Inline signature images are left untouched.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Smart</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">↩️</div>
          <div class="text-base font-bold text-text mb-2">Keep 2 replies</div>
          <div class="text-sm text-text-muted leading-relaxed">Trims long threads to the 2 most recent messages. Detects quoted blocks in all Outlook formats and multiple languages.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">Multi-language</span>
        </div>
        <div class="bg-surface border border-border rounded-2xl p-7 transition hover:border-success hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">✂️</div>
          <div class="text-base font-bold text-text mb-2">Keep selection</div>
          <div class="text-sm text-text-muted leading-relaxed">Replace the entire quoted thread with just the passage you selected. Surgical precision.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">HTML selection</span>
        </div>
        <div class="bg-gradient-to-br from-success-bg to-background border border-success/30 rounded-2xl p-7 transition hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">✅</div>
          <div class="text-base font-bold text-text mb-2">Full cleanup</div>
          <div class="text-sm text-text-muted leading-relaxed">Runs all actions at once. A detailed summary appears: images, attachments, replies — all in one go.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-success-bg text-success px-2.5 py-0.5 rounded-full">All-in-one</span>
        </div>
        <div class="bg-gray-900 border border-transparent rounded-2xl p-7 transition hover:shadow-md hover:-translate-y-0.5">
          <div class="text-3xl mb-3">🔒</div>
          <div class="text-base font-bold text-white mb-2">100% local</div>
          <div class="text-sm text-gray-400 leading-relaxed">All processing happens in Outlook via the Office.js API. No data is ever sent to an external server.</div>
          <span class="inline-block mt-3 text-[0.7rem] font-bold uppercase tracking-wide bg-green-400/15 text-green-400 px-2.5 py-0.5 rounded-full">Privacy first</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 px-6 bg-surface" id="how">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-success mb-3">🚀 How it works</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight mb-2">Three steps, done.</h2>
      <p class="text-base text-text-muted mb-12">No complex setup. No account to create.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-6">
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">1</div>
          <div class="font-bold text-text mb-1">Install the add-in</div>
          <div class="text-sm text-text-muted leading-relaxed">Download MailLighter from Microsoft AppSource and add it to Outlook in seconds.</div>
        </div>
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">2</div>
          <div class="font-bold text-text mb-1">Compose your email</div>
          <div class="text-sm text-text-muted leading-relaxed">Write or reply to an email as usual. The MailLighter menu is available in the ribbon.</div>
        </div>
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-full bg-green-600 text-white font-extrabold text-lg flex items-center justify-center mx-auto mb-4">3</div>
          <div class="font-bold text-text mb-1">Lighten before sending</div>
          <div class="text-sm text-text-muted leading-relaxed">Choose the desired action. MailLighter runs instantly and shows you what was removed.</div>
        </div>
      </div>

      <div class="mt-10 bg-gray-900 rounded-xl px-6 py-5 flex items-center gap-3 text-left max-w-xl mx-auto">
        <span class="text-2xl shrink-0">✅</span>
        <span class="text-sm text-green-200 font-mono">Full cleanup — Images: 8 (1.2 MB) | Attachments: 2 (3.4 MB) | Replies: 6 → 2</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 text-center" id="download">
    <div class="max-w-2xl mx-auto">
      <div class="inline-flex items-center gap-1.5 bg-success-bg border border-success/30 text-success px-4 py-1.5 rounded-full text-xs font-semibold mb-5">🌿 Adopt the responsible email reflex</div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight mb-4">Ready to lighten your emails <span class="bg-gradient-to-r from-green-700 to-green-500 bg-clip-text text-transparent">and your impact?</span></h2>
      <p class="text-base text-text-muted mb-8 leading-relaxed">Free, no account, no data collection. Install MailLighter in seconds and start sending cleaner emails today.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="https://appsource.microsoft.com/" class="inline-flex items-center gap-2 bg-green-600 text-white px-7 py-3.5 rounded-xl font-bold shadow-lg shadow-green-600/30 transition hover:bg-green-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-green-600/40">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Install for free
        </a>
      </div>
      <p class="text-xs text-text-muted mt-4">Outlook Desktop · Windows &amp; macOS · Microsoft 365 or Exchange</p>
    </div>
  </section>
</MarketingLayout>

<style>
  @keyframes slide {
    0%, 100% { transform: translateX(0); opacity: 0.6; }
    50% { transform: translateX(7px); opacity: 1; }
  }
  .arrow-anim { animation: slide 2s ease-in-out infinite; }
</style>
